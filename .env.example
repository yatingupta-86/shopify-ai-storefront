# Copy this file to .env and fill in your values
# cp .env.example .env

# Shopify
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2026-04

# Shopify App OAuth
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=your_client_secret

# Chatbot (get free key at console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Product enrichment agent
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Review queue admin password
ADMIN_TOKEN=your-secret-admin-token

# Langfuse LLM observability (optional — free tier at cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# Supabase (optional — free tier at supabase.com, used to persist agent cost ledger)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-anon-public-key

# Observability (optional — free tier at sentry.io)
SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
ENVIRONMENT=production
LOG_LEVEL=INFO
